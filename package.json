{
  "name": "pauperwave_blog",
  "private": true,
  "type": "module",
  "scripts": {
    "download-cards": "bun run scripts/download-bulk-data.ts",
    "prebuild": "echo '✅ Using pre-built Pauper database'",
    "build": "nuxt build",
    "update-cards": "bun run download-cards",
    "dev": "nuxt dev",
    "dev:clean": "rm -rf .nuxt .data && nuxt dev",
    "clean": "nuxt cleanup",
    "clean:all": "nuxt cleanup && rm -rf .data",
    "clean:content": "rm -rf .data",
    "pregenerate": "bun run download-cards",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "typecheck": "nuxt typecheck",
    "bench:filters": "bun run scripts/benchmark-article-filters.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@nuxt/content": "^3.11.2",
    "@nuxt/eslint": "1.13.0",
    "@nuxt/icon": "2.2.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.5.0",
    "@nuxtjs/mdc": "^0.20.1",
    "@nuxtjs/seo": "^3.3.0",
    "better-sqlite3": "^12.6.2",
    "dayjs": "^1.11.19",
    "eslint": "^9.0.0",
    "magic-regexp": "^0.10.0",
    "mana-font": "^1.18.0",
    "nuxt": "^4.3.1",
    "nuxt-studio": "1.2.0",
    "nuxt-swiper": "2.0.1"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.95",
    "@iconify-json/simple-icons": "^1.2.71",
