    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.6",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.1.0",
    "happy-dom": "^20.3.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  }
